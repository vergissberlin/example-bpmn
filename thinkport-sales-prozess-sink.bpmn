<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Sales" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <bpmn:collaboration id="Collaboration_Sales">
    <bpmn:participant id="Participant_Thinkport" name="Thinkport" processRef="Process_Thinkport" />
    <bpmn:participant id="Participant_Kunde" name="Kunde" processRef="Process_Kunde" />
    <bpmn:messageFlow id="MessageFlow_Angebot" name="Angebot" sourceRef="EndEvent_AngebotVersendet" targetRef="StartEvent_AngebotErhalten" />
    <bpmn:messageFlow id="MessageFlow_Auftrag" name="Auftrag" sourceRef="EndEvent_AuftragErteilt" targetRef="StartEvent_AuftragErhalten" />
    <bpmn:messageFlow id="MessageFlow_Ablehnung" name="Ablehnung" sourceRef="EndEvent_Abgelehnt" targetRef="StartEvent_AblehnungErhalten" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Thinkport" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Thinkport">
      <bpmn:lane id="Lane_Sales" name="Sales">
        <bpmn:flowNodeRef>StartEvent_Lead</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Qualifizieren</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Qualifiziert</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AngebotErstellen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AngebotVersenden</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_AngebotVersendet</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_AuftragErhalten</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VertragAufsetzen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Uebergabe</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_AblehnungErhalten</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_AuftragVerloren</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Verworfen</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Delivery" name="Delivery">
        <bpmn:flowNodeRef>Task_KickoffVorbereiten</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ProjektGestartet</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Lead" name="Lead eingegangen">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Qualifizieren" name="Lead qualifizieren">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Qualifiziert" name="Qualifiziert?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_AngebotErstellen" name="Angebot erstellen">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AngebotVersenden" name="Angebot versenden">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_AngebotVersendet" name="Angebot versendet">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1" />
    </bpmn:endEvent>
    <bpmn:startEvent id="StartEvent_AuftragErhalten" name="Auftrag erhalten">
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_2" />
    </bpmn:startEvent>
    <bpmn:task id="Task_VertragAufsetzen" name="Vertrag aufsetzen">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Uebergabe" name="An Delivery übergeben">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:startEvent id="StartEvent_AblehnungErhalten" name="Ablehnung erhalten">
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_3" />
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_AuftragVerloren" name="Auftrag verloren">
      <bpmn:incoming>Flow_11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_Lead" targetRef="Task_Qualifizieren" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Qualifizieren" targetRef="Gateway_Qualifiziert" />
    <bpmn:sequenceFlow id="Flow_3" name="Nein" sourceRef="Gateway_Qualifiziert" targetRef="EndEvent_Verworfen" />
    <bpmn:sequenceFlow id="Flow_4" name="Ja" sourceRef="Gateway_Qualifiziert" targetRef="Task_AngebotErstellen" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_AngebotErstellen" targetRef="Task_AngebotVersenden" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_AngebotVersenden" targetRef="EndEvent_AngebotVersendet" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="StartEvent_AuftragErhalten" targetRef="Task_VertragAufsetzen" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_VertragAufsetzen" targetRef="Task_Uebergabe" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_Uebergabe" targetRef="Task_KickoffVorbereiten" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_KickoffVorbereiten" targetRef="EndEvent_ProjektGestartet" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="StartEvent_AblehnungErhalten" targetRef="EndEvent_AuftragVerloren" />
    <bpmn:task id="Task_KickoffVorbereiten" name="Kickoff vorbereiten">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_ProjektGestartet" name="Projekt gestartet">
      <bpmn:incoming>Flow_10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Verworfen" name="Lead verworfen">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmn:process id="Process_Kunde" isExecutable="false">
    <bpmn:endEvent id="EndEvent_Abgelehnt" name="Angebot abgelehnt">
      <bpmn:incoming>Flow_K3</bpmn:incoming>
