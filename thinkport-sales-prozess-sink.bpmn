    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_K3" name="Nein" sourceRef="Gateway_Angenommen" targetRef="EndEvent_Abgelehnt" />
    <bpmn:endEvent id="EndEvent_AuftragErteilt" name="Auftrag erteilt">
      <bpmn:incoming>Flow_K4</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_6" />
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_Angenommen" name="Angenommen?">
      <bpmn:incoming>Flow_K2</bpmn:incoming>
      <bpmn:outgoing>Flow_K3</bpmn:outgoing>
      <bpmn:outgoing>Flow_K4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_AngebotPruefen" name="Angebot prüfen">
      <bpmn:incoming>Flow_K1</bpmn:incoming>
      <bpmn:outgoing>Flow_K2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:startEvent id="StartEvent_AngebotErhalten" name="Angebot erhalten">
      <bpmn:outgoing>Flow_K1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_4" />
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_K4" name="Ja" sourceRef="Gateway_Angenommen" targetRef="EndEvent_AuftragErteilt" />
    <bpmn:sequenceFlow id="Flow_K2" sourceRef="Task_AngebotPruefen" targetRef="Gateway_Angenommen" />
    <bpmn:sequenceFlow id="Flow_K1" sourceRef="StartEvent_AngebotErhalten" targetRef="Task_AngebotPruefen" />
  </bpmn:process>
